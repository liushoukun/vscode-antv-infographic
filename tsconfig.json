{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2022",
    "lib": ["ES2022"],
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "declaration": false
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "node_modules",
    "src/preview.ts",
    "src/editorWebview.ts",
    "src/webviewExportMc.ts",
    "src/mcToolbarIcons.ts"
  ]
}
