{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "AntV Infographic",
  "scopeName": "source.infographic",
  "patterns": [
    { "include": "#comments" },
    { "include": "#infographic-declaration" },
    { "include": "#theme-or-template-preset" },
    { "include": "#block-header-line" },
    { "include": "#key-value-line" },
    { "include": "#strings" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.infographic",
          "match": "#.*$"
        }
      ]
    },
    "infographic-declaration": {
      "patterns": [
        {
          "match": "(?x) ^ \\s* (infographic) \\s+ ([-\\w]+) \\s* $",
          "captures": {
            "1": { "name": "keyword.control.infographic" },
            "2": { "name": "entity.name.type.infographic" }
          }
        }
      ]
    },
    "theme-or-template-preset": {
      "patterns": [
        {
          "match": "(?x) ^ \\s* (theme) \\s+ (.+?) \\s* $",
          "captures": {
            "1": { "name": "keyword.control.infographic" },
            "2": { "name": "string.unquoted.infographic" }
          }
        },
        {
          "match": "(?x) ^ \\s* (template) \\s+ (.+?) \\s* $",
          "captures": {
            "1": { "name": "keyword.control.infographic" },
            "2": { "name": "entity.name.type.infographic" }
          }
        }
      ]
    },
    "block-header-line": {
      "patterns": [
        {
          "name": "keyword.control.infographic",
          "match": "(?x) ^ \\s* (?: data | design | template | theme | infographic ) \\s* $"
        }
      ]
    },
    "key-value-line": {
      "patterns": [
        {
          "match": "(?x) ^ \\s* (?: - \\s+ )? ([A-Za-z_][\\w.-]*) ( \\s+ .+ )? \\s* $",
          "captures": {
            "1": { "name": "support.type.property-name.infographic" },
            "2": { "name": "meta.value.infographic" }
          }
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.infographic",
          "begin": "\"",
          "end": "\"",
          "patterns": [{ "include": "#string-escape" }]
        },
        {
          "name": "string.quoted.single.infographic",
          "begin": "'",
          "end": "'",
          "patterns": [{ "include": "#string-escape" }]
        }
      ]
    },
    "string-escape": {
      "patterns": [
        {
          "name": "constant.character.escape.infographic",
          "match": "\\\\."
        }
      ]
    }
  }
}
