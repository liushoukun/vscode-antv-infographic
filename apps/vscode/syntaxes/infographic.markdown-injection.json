{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "fileTypes": [],
  "scopeName": "markdown.infographic.codeblock",
  "injectionSelector": "L:markup.fenced_code.block.markdown",
  "patterns": [{ "include": "#infographic-code-block" }],
  "repository": {
    "infographic-code-block": {
      "begin": "\\G((?i:infographic))(\\s+[^`~]*)?$",
      "end": "(^|\\G)(?=\\s*[`~]{3,}\\s*$)",
      "beginCaptures": {
        "1": { "name": "fenced_code.block.language.markdown" },
        "2": { "name": "fenced_code.block.language.attributes.markdown" }
      },
      "patterns": [
        {
          "begin": "(^|\\G)(\\s*)(.*)",
          "while": "(^|\\G)(?!\\s*([`~]{3,})\\s*$)",
          "contentName": "meta.embedded.block.infographic",
          "patterns": [{ "include": "source.infographic" }]
        }
      ]
    }
  }
}
